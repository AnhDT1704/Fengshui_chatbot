# Copy this file to .env and fill in real values.
# NEVER commit the actual .env (it is gitignored).

# ── OpenRouter (used for text-embedding-3-small) ───────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# ── PostgreSQL ─────────────────────────────────────────────────────────
# When running via docker compose, leave host=localhost for host-side
# tools; the chatbot container overrides PG_HOST=postgres at runtime.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=fengshui_db
PG_USER=fengshui_user
PG_PASSWORD=fengshui_pass

# ── OpenSearch ─────────────────────────────────────────────────────────
OS_HOST=localhost
OS_PORT=9200
OS_INDEX=fengshui_products

# ── Embedding model ────────────────────────────────────────────────────
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ── Chatbot — Gemini (REQUIRED) ────────────────────────────────────────
# Free keys at https://aistudio.google.com/apikey
# Add as many as you want — KEY1, KEY2, ... — and the chatbot will
# automatically rotate when one hits its quota.
GOOGLE_API_KEY1=REPLACE_ME
# GOOGLE_API_KEY2=REPLACE_ME
# GOOGLE_API_KEY3=REPLACE_ME
# GOOGLE_API_KEY4=REPLACE_ME

# ── Chatbot — SerpAPI (optional) ───────────────────────────────────────
# Used by skills_agent.web_search_tool. Tool returns a graceful fallback
# if this is left empty.
SERPAPI_KEY=

# ── Chatbot — model + memory ───────────────────────────────────────────
CHATBOT_MODEL=gemini-2.5-flash
CHATBOT_MEMORY_LIMIT=20
